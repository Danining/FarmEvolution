<!DOCTYPE html>
<html>
<head>
    <title>Farm Evolution - Stable Version</title>
    <style>
        /* (기존 CSS 스타일과 동일하게 유지됩니다) */
        body { margin: 0; overflow: hidden; background: #5cb85c; display: flex; justify-content: center; align-items: center; height: 100vh; font-family: 'Malgun Gothic', sans-serif; }
        canvas { background: #6b8e23; border: 5px solid #4a6c1e; display: none; cursor: crosshair; }
        .panel { position: absolute; background: rgba(0,0,0,0.85); color: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); display: none; }
        #infoPanel { top: 20px; left: 20px; min-width: 220px; }
        .side-btns { position: absolute; top: 20px; right: 20px; display: flex; flex-direction: column; gap: 10px; }
        .btn-circle { width: 50px; height: 50px; border-radius: 50%; border: none; font-size: 20px; cursor: pointer; background: white; }
        .popup { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400px; max-height: 80vh; overflow-y: auto; z-index: 100; }
        .tab-bar { display: flex; gap: 5px; margin-bottom: 15px; }
        .tab-bar button { flex: 1; padding: 5px; cursor: pointer; background: #444; color: white; border: none; border-radius: 5px; }
        .tab-bar button.active { background: #5cb85c; }
        .dex-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
        .dex-item { background: #333; padding: 10px; border-radius: 8px; font-size: 24px; text-align: center; }
        .rank-item { display: flex; justify-content: space-between; padding: 8px; border-bottom: 1px solid #444; }
        .auth-container { background: white; padding: 30px; border-radius: 12px; width: 300px; text-align: center; }
        .auth-container input { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box; }
        .pass-box { position: relative; }
        .view-toggle { position: absolute; right: 10px; top: 18px; cursor: pointer; font-size: 14px; color: #555; }
    </style>
</head>
<body>

    <div id="auth-screen" class="auth-container">
        <h2 style="color: #2e7d32;">Farm Evolution</h2>
        <input type="email" id="email" placeholder="이메일">
        <div class="pass-box">
            <input type="password" id="password" placeholder="비밀번호">
            <span class="view-toggle" onclick="togglePass()">👁️</span>
        </div>
        <button id="btn-login" style="width:100%; background:#5cb85c; color:white; border:none; padding:10px; border-radius:5px; margin-top:10px; cursor:pointer; font-weight:bold;">로그인</button>
        <button id="btn-signup" style="width:100%; background:white; color:#5cb85c; border:1px solid #5cb85c; padding:10px; border-radius:5px; margin-top:5px; cursor:pointer; font-weight:bold;">회원가입</button>
    </div>

    <div id="infoPanel" class="panel">
        <div style="font-size: 18px; margin-bottom: 10px;">🚜 <span id="display-id">@로딩중...</span></div>
        <div>⏱️ 누적: <span id="playTime">00:00:00</span></div>
        <div>⭐ 레벨: <span id="level">1</span> <span style="font-size:12px; color:#aaa;">(<span id="exp-display">0/5</span>)</span></div>
        <div>💰 보유금: <span id="money">100</span>원</div>
        <button onclick="logout()" style="margin-top:15px; width:100%; background:#d9534f; color:white; border:none; padding:8px; cursor:pointer; border-radius:5px; font-weight:bold;">로그아웃</button>
    </div>

    <div class="side-btns" id="game-btns" style="display:none;">
        <button class="btn-circle" onclick="openDex()" title="도감">📖</button>
        <button class="btn-circle" onclick="openRank()" title="리더보드">🏆</button>
    </div>

    <div id="dex-popup" class="panel popup">
        <h3>📖 발견한 작물</h3>
        <div class="dex-grid" id="dex-grid"></div>
        <button onclick="closeAll()" style="width:100%; margin-top:20px; padding:10px; cursor:pointer;">닫기</button>
    </div>

    <div id="rank-popup" class="panel popup">
        <h3>🏆 리더보드</h3>
        <div class="tab-bar">
            <button id="tab-time" onclick="showRank('playTime')">시간</button>
            <button id="tab-money" onclick="showRank('money')">자산</button>
            <button id="tab-level" onclick="showRank('level')">레벨</button>
        </div>
        <div id="rank-list"></div>
        <button onclick="closeAll()" style="width:100%; margin-top:20px; padding:10px; cursor:pointer;">닫기</button>
    </div>

    <canvas id="gameCanvas"></canvas>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, updateDoc, collection, query, orderBy, limit, getDocs, where } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyANW6V8ys3jhSX5KW9h_BCA9Z9VFLTkzq0",
            authDomain: "farmgame-8c07f.firebaseapp.com",
            projectId: "farmgame-8c07f",
            storageBucket: "farmgame-8c07f.firebasestorage.app",
            messagingSenderId: "357555224241",
            appId: "1:357555224241:web:1de05121b0db456bd9ec90"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = 800; canvas.height = 600;
        const TILE_SIZE = 50;
        const cropList = ['🥕','🍅','🌽','🥔','🍎','🍓','🍇','🍈','🍉','🍑','🍍','🥭','🥝','🍒','🍐','🍋‍🟩','🍄','🥦','🥑','🌶️','🌹','🌷','🌸','🌼','🌻'];

        // 데이터 초기 상태 (NaN 방지)
        let userData = { 
            money: 100, 
            level: 1, 
            exp: 0, 
            playTime: 0, 
            farm: Array.from({length: 12}, () => Array(16).fill(0)), 
            dex: [], 
            customId: "@User" 
        };
        let growthTimers = Array.from({length: 12}, () => Array(16).fill(0));
        let isLoaded = false;

        async function generateCustomId(email) {
            const prefix = email.substring(0, 3).toLowerCase();
            const q = query(collection(db, "users"), where("idPrefix", "==", prefix));
            const snapshot = await getDocs(q);
            const count = snapshot.size + 1;
            return `@${prefix}${String(count).padStart(3, '0')}`;
        }

        onAuthStateChanged(auth, async (user) => {
            if (user) {
                const docRef = doc(db, "users", user.uid);
                const userDoc = await getDoc(docRef);
                
                if (userDoc.exists()) {
                    const data = userDoc.data();
                    userData = {
                        ...userData,
                        ...data,
                        farm: typeof data.farm === 'string' ? JSON.parse(data.farm) : data.farm
                    };
                } else {
                    const cId = await generateCustomId(user.email);
                    userData = {
                        customId: cId,
                        idPrefix: user.email.substring(0, 3).toLowerCase(),
                        money: 100, level: 1, exp: 0, playTime: 0,
                        dex: [], 
                        farm: Array.from({length: 12}, () => Array(16).fill(0))
                    };
                    await setDoc(docRef, { ...userData, farm: JSON.stringify(userData.farm) });
                }
                
                isLoaded = true;
                document.getElementById('auth-screen').style.display = 'none';
                document.getElementById('infoPanel').style.display = 'block';
                document.getElementById('game-btns').style.display = 'flex';
                canvas.style.display = 'block';
                document.getElementById('display-id').innerText = userData.customId;

                // 타이머 및 루프 시작
                setInterval(() => { 
                    if(isLoaded) { 
                        userData.playTime = (userData.playTime || 0) + 1; 
                        updateUI(); 
                        if(userData.playTime % 15 === 0) save(); 
                    } 
                }, 1000);
                gameLoop();
            } else {
                isLoaded = false;
                document.getElementById('auth-screen').style.display = 'block';
                document.getElementById('infoPanel').style.display = 'none';
                document.getElementById('game-btns').style.display = 'none';
                canvas.style.display = 'none';
            }
        });

        async function save() {
            if (!isLoaded || !auth.currentUser) return;
            try {
                await updateDoc(doc(db, "users", auth.currentUser.uid), {
                    ...userData, 
                    farm: JSON.stringify(userData.farm)
                });
            } catch (e) { console.warn("Save sync delay..."); }
        }

        function drawFarm() {
            if (!isLoaded) return;
            ctx.clearRect(0,0,800,600);
            userData.farm.forEach((row, r) => {
                row.forEach((cell, c) => {
                    const x = c*TILE_SIZE, y = r*TILE_SIZE;
                    ctx.fillStyle = cell === 0 ? '#8B4513' : (cell === 4 ? '#6D4C41' : '#5D4037');
                    ctx.fillRect(x, y, TILE_SIZE, TILE_SIZE);
                    ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.strokeRect(x,y,TILE_SIZE,TILE_SIZE);
                    
                    const cropIdx = Math.min(Math.floor(((userData.level || 1)-1)/2), cropList.length-1);
                    const nowCrop = cropList[cropIdx];
                    ctx.font = '24px Arial';
                    ctx.textAlign = 'center';
                    if(cell === 2) ctx.fillText('🌱', x+25, y+30);
                    else if(cell === 3) ctx.fillText('🌿', x+25, y+30);
                    else if(cell === 4) ctx.fillText(nowCrop, x+25, y+30);
                });
            });
        }

        canvas.addEventListener('click', (e) => {
            if(!isLoaded) return;
            const rect = canvas.getBoundingClientRect();
            const c = Math.floor((e.clientX - rect.left)/TILE_SIZE);
            const r = Math.floor((e.clientY - rect.top)/TILE_SIZE);
            if(r < 0 || r >= 12 || c < 0 || c >= 16) return;
            
            const state = userData.farm[r][c];

            if(state === 0 && userData.money >= 10) { 
                userData.money -= 10; userData.farm[r][c] = 1; 
            } else if(state === 1 && userData.money >= 5) { 
                userData.money -= 5; userData.farm[r][c] = 2; 
                growthTimers[r][c] = Date.now() + 3000; 
            } else if(state === 4) {
                const cropIdx = Math.min(Math.floor(((userData.level || 1)-1)/2), cropList.length-1);
                const crop = cropList[cropIdx];
                if(!userData.dex.includes(crop)) userData.dex.push(crop);
                userData.money += (20 + (userData.level*5));
                userData.exp++;
                if(userData.exp >= userData.level*5) { 
                    userData.level++; userData.exp=0; 
                    alert("Lv Up! 더 비싼 작물을 키웁니다!"); 
                }
                userData.farm[r][c] = 0;
            }
            updateUI();
            save();
        });

        function gameLoop() {
            if(!isLoaded) return;
            const now = Date.now();
            userData.farm.forEach((row, r) => {
                row.forEach((cell, c) => {
                    if(cell === 2 && now >= growthTimers[r][c]) userData.farm[r][c] = 3;
                    else if(cell === 3 && now >= growthTimers[r][c]+3000) userData.farm[r][c] = 4;
                });
            });
            drawFarm();
            requestAnimationFrame(gameLoop);
        }

        window.togglePass = () => {
            const p = document.getElementById('password');
            p.type = p.type === 'password' ? 'text' : 'password';
        };

        window.openDex = () => {
            closeAll();
            const grid = document.getElementById('dex-grid');
            grid.innerHTML = cropList.map(c => `<div class="dex-item">${(userData.dex || []).includes(c) ? c : '❓'}</div>`).join('');
            document.getElementById('dex-popup').style.display = 'block';
        };

        window.showRank = async (type) => {
            document.querySelectorAll('.tab-bar button').forEach(b => b.classList.remove('active'));
            const btnId = type === 'playTime' ? 'tab-time' : (type === 'money' ? 'tab-money' : 'tab-level');
            document.getElementById(btnId).classList.add('active');
            
            const q = query(collection(db, "users"), orderBy(type, "desc"), limit(10));
            const snap = await getDocs(q);
            let html = "";
            let i = 1;
            snap.forEach(doc => {
                const d = doc.data();
                let val = d[type];
                if(type === 'playTime') val = formatTime(val || 0);
                else if(type === 'money') val = (val || 0).toLocaleString() + "원";
                else val = "Lv." + (val || 1);
                html += `<div class="rank-item"><span>${i++}. ${d.customId || '@User'}</span><span>${val}</span></div>`;
            });
            document.getElementById('rank-list').innerHTML = html || "데이터가 없습니다.";
        };

        window.openRank = () => { closeAll(); document.getElementById('rank-popup').style.display = 'block'; showRank('playTime'); };
        window.closeAll = () => { 
            document.getElementById('dex-popup').style.display = 'none'; 
            document.getElementById('rank-popup').style.display = 'none'; 
        };
        window.logout = () => signOut(auth);

        function formatTime(s) {
            if(isNaN(s)) return "00:00:00";
            const h = String(Math.floor(s/3600)).padStart(2,'0');
            const m = String(Math.floor((s%3600)/60)).padStart(2,'0');
            const sc = String(s%60).padStart(2,'0');
            return `${h}:${m}:${sc}`;
        }

        function updateUI() {
            document.getElementById('money').innerText = (userData.money || 0).toLocaleString();
            document.getElementById('level').innerText = userData.level || 1;
            document.getElementById('exp-display').innerText = `${userData.exp || 0}/${(userData.level || 1)*5}`;
            document.getElementById('playTime').innerText = formatTime(userData.playTime || 0);
        }

        document.getElementById('btn-login').onclick = () => {
            const email = document.getElementById('email').value;
            const pass = document.getElementById('password').value;
            if(!email || !pass) return alert("입력해주세요!");
            signInWithEmailAndPassword(auth, email, pass).catch(e => alert("로그인 실패: 정보를 확인하세요."));
        };
        document.getElementById('btn-signup').onclick = () => {
            const email = document.getElementById('email').value;
            const pass = document.getElementById('password').value;
            if(!email || !pass) return alert("입력해주세요!");
            createUserWithEmailAndPassword(auth, email, pass).catch(e => alert("가입 실패: 이미 있는 계정이거나 형식이 틀립니다."));
        };
    </script>
</body>
</html>
